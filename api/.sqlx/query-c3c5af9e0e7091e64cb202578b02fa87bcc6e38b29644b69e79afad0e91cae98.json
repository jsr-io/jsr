  "query": "SELECT id, status as \"status: PublishingTaskStatus\"\n      FROM publishing_tasks\n      WHERE status IN ('processing', 'processed')\n        AND updated_at < now() - ($1::bigint * interval '1 second')\n      ORDER BY updated_at ASC\n      LIMIT 1000",
